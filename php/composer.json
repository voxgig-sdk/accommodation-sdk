{
  "name": "voxgig-sdk/accommodation",
  "description": "Unofficial generated PHP SDK for the Accommodation public API. Not affiliated with or endorsed by the upstream API provider.",
  "type": "library",
  "keywords": ["voxgig", "sdk", "generated-sdk", "openapi", "api-client", "accommodation"],
  "homepage": "https://github.com/voxgig-sdk/accommodation-sdk",
  "license": "MIT",
  "authors": [
    { "name": "Voxgig", "homepage": "https://voxgig.com" }
  ],
  "support": {
    "issues": "https://github.com/voxgig-sdk/accommodation-sdk/issues",
    "source": "https://github.com/voxgig-sdk/accommodation-sdk"
  },
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Accommodation\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Accommodation\\Tests\\": "test/"
    }
  }
}
